# Stripe Card Details
# Copy this file to .env and fill in your actual values
CARD_NUMBER=0000000000000000
CARD_EXPIRY=MM/YY
CARD_CVC=000

# Use "random" for auto-generated names, or set a fixed value
CARD_NAME=random

# Use "random" for auto-generated addresses, or set a fixed value
ADDRESS=random

# Use "random" for auto-generated city, or set a fixed value
CITY=random
