{
  "manifest_version": 3,
  "name": "Windsurf Auto Trial Account Creator",
  "version": "1.0.0",
  "description": "Auto-register Windsurf trial accounts using temp mail",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://windsurf.com/*",
    "https://checkout.stripe.com/*",
    "https://asportshd.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://windsurf.com/*", "https://checkout.stripe.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [".env"],
      "matches": ["<all_urls>"]
    }
  ]
}
